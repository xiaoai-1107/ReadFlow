                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Offline support matters most at the exact place where reading was interrupted; that is why cache status belongs beside the paragraph, not buried in a secondary settings page.",
                          "lineHeight": 1.78,
                          "fontFamily": "$font_ui",
                          "fontSize": 17,
