                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Reading in the original language preserves the author’s cadence. Translation should stand nearby as support, but the eye must still land first on the original sentence.",
                              "lineHeight": 1.78,
                              "fontFamily": "$font_ui",
                              "fontSize": 17,
